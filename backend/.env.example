# LLM Configuration (required)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_PROVIDER=openai

# Rust Compute Node (optional, default: http://localhost:8080)
COMPUTE_NODE_URL=http://localhost:8080

# Agent (optional overrides)
AGENT_MAX_TURNS=50
TOOL_SHELL_TIMEOUT=30
